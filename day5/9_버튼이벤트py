from tkinter import *

count = 0

def clicked() :
    # print(label['text'])
    global count
    count += 1
    label['text'] = count

window = Tk()
window.geometry("350x350")

label = Label(window, text="버튼을 클릭하세요.")
label.pack()
Button(window, text="클릭!", command=clicked).pack()
window.mainloop()